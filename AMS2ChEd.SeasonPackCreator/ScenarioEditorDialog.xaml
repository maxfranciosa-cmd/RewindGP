<Window x:Class="AMS2ChEd.SeasonPackEditor.ScenarioEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Scenario Editor"
        Width="540" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#1A1A1A">

    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryBrush"       Color="#E10600"/>
        <SolidColorBrush x:Key="BackgroundBrush"    Color="#1A1A1A"/>
        <SolidColorBrush x:Key="SurfaceBrush"       Color="#2D2D2D"/>
        <SolidColorBrush x:Key="TextBrush"          Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#B0B0B0"/>
        <SolidColorBrush x:Key="BorderBrush"        Color="#404040"/>

        <Style x:Key="Label" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Margin"     Value="0,0,0,4"/>
        </Style>

        <Style x:Key="Field" TargetType="TextBox">
            <Setter Property="Background"            Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="Foreground"            Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush"           Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness"       Value="1"/>
            <Setter Property="Padding"               Value="8,6"/>
            <Setter Property="FontSize"              Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="Btn" TargetType="Button">
            <Setter Property="Background"    Value="#404040"/>
            <Setter Property="Foreground"    Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"       Value="14,7"/>
            <Setter Property="FontSize"      Value="12"/>
            <Setter Property="Cursor"        Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="2"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4A4A4A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SaveBtn" TargetType="Button" BasedOn="{StaticResource Btn}">
            <Setter Property="Background" Value="#E10600"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF1800"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/><!-- Name -->
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/><!-- Description -->
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/><!-- Picture -->
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/><!-- Game File -->
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/><!-- Buttons -->
        </Grid.RowDefinitions>

        <!-- Name -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="Name" Style="{StaticResource Label}"/>
            <TextBox x:Name="NameTextBox" Style="{StaticResource Field}" Height="32"/>
        </StackPanel>

        <!-- Description -->
        <StackPanel Grid.Row="2">
            <TextBlock Text="Description" Style="{StaticResource Label}"/>
            <TextBox x:Name="DescriptionTextBox" Style="{StaticResource Field}"
                     Height="72" TextWrapping="Wrap" AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"
                     VerticalContentAlignment="Top"/>
        </StackPanel>

        <!-- Picture -->
        <StackPanel Grid.Row="4">
            <TextBlock Text="Picture File" Style="{StaticResource Label}"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="PicturePathTextBox" Grid.Column="0"
                         Style="{StaticResource Field}" Height="32" IsReadOnly="True"/>
                <Button Grid.Column="2" Content="Browse…" Style="{StaticResource Btn}"
                        Height="32" Click="BrowsePicture_Click"/>
            </Grid>
        </StackPanel>

        <!-- Game File -->
        <StackPanel Grid.Row="6">
            <TextBlock Text="Game Save File (.json)" Style="{StaticResource Label}"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="GameFilePathTextBox" Grid.Column="0"
                         Style="{StaticResource Field}" Height="32" IsReadOnly="True"/>
                <Button Grid.Column="2" Content="Browse…" Style="{StaticResource Btn}"
                        Height="32" Click="BrowseGameFile_Click"/>
            </Grid>
        </StackPanel>

        <!-- Action buttons -->
        <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Style="{StaticResource Btn}"
                    Margin="0,0,10,0" Click="Cancel_Click"/>
            <Button Content="Save" Style="{StaticResource SaveBtn}"
                    Width="90" Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
