<Window x:Class="AMS2ChEd.SeasonPackEditor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AMS2ChEd.SeasonPackEditor"
        xmlns:controls="clr-namespace:AMS2ChEd.SeasonPackEditor.Controls"
        xmlns:helmet="clr-namespace:AMS2ChEd.SeasonPackEditor.HelmetEditor.Controls"
        mc:Ignorable="d"
        Title="Rewind GP - Season Pack Editor" 
        Height="800" 
        Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#1A1A1A">

    <Window.Resources>
        <!-- Converter for hex color strings -->
        <local:StringToBrushConverter x:Key="StringToBrushConverter"/>

        <!-- Base Colors -->
        <SolidColorBrush x:Key="PrimaryBrush" Color="#E10600"/>
        <SolidColorBrush x:Key="BackgroundBrush" Color="#1A1A1A"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#2D2D2D"/>
        <SolidColorBrush x:Key="TextBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#B0B0B0"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#404040"/>

        <!-- Tab Control Style -->
        <Style x:Key="ModernTabControl" TargetType="TabControl">
            <Setter Property="Background" Value="{StaticResource BackgroundBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <Style x:Key="ModernTabItem" TargetType="TabItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border Name="Border" 
                                Background="{StaticResource SurfaceBrush}" 
                                BorderThickness="0,0,0,3" 
                                BorderBrush="Transparent"
                                Padding="20,12"
                                Margin="0,0,2,0">
                            <ContentPresenter x:Name="ContentSite"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Center"
                                            ContentSource="Header"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                                <Setter TargetName="Border" Property="Background" Value="#242424"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#333333"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
        </Style>

        <Style x:Key="ModernCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,3"/>
        </Style>

        <!-- TextBox Style -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- ComboBox Style -->
        <Style x:Key="ModernComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="32"/>
        </Style>

        <!-- Button Style -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="2"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF1800"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#555555"/>
                    <Setter Property="Foreground" Value="#888888"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#404040"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4A4A4A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Label Style -->
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="0,0,0,5"/>
        </Style>

        <!-- DataGrid Style -->
        <Style x:Key="ModernDataGrid" TargetType="DataGrid">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="RowBackground" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="AlternatingRowBackground" Value="#242424"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#1F1F1F"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#333333"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#404040"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#0D0D0D" BorderBrush="{StaticResource PrimaryBrush}" BorderThickness="0,0,0,2" Padding="20,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="REWIND GP" FontSize="20" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>
                    <TextBlock Text="Season Pack Editor" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="New Project" Style="{StaticResource SecondaryButton}" Margin="0,0,10,0" Click="NewSeason_Click"/>
                    <Button Content="Load Project" Style="{StaticResource SecondaryButton}" Margin="0,0,10,0" Click="LoadSeason_Click"/>
                    <Button Content="Save Project" Style="{StaticResource SecondaryButton}" Click="SaveSeason_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <TabControl Grid.Row="1" 
                    x:Name="MainTabControl"
                    Style="{StaticResource ModernTabControl}"
                    SelectionChanged="MainTabControl_SelectionChanged"
                    Margin="0">

            <!-- General Information Tab -->
            <TabItem Header="GENERAL" Style="{StaticResource ModernTabItem}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="30,20">
                        <TextBlock Text="Season Information" FontSize="18" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,20"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="400"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Label Grid.Row="0" Grid.Column="0" Content="Year:" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Name="YearTextBox" Style="{StaticResource ModernTextBox}" Margin="0,0,0,15"/>

                            <Label Grid.Row="2" Grid.Column="0" Content="AMS2 Class:" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="2" Grid.Column="1" Name="Ams2ClassTextBox" Style="{StaticResource ModernTextBox}" Margin="0,0,0,15"/>
                            <TextBlock Grid.Row="2" Grid.Column="2" Text="(e.g., F_V10, F_VINTAGE)" 
                                       Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="10,0,0,15"/>
                            <Button Grid.Row="3" Style="{StaticResource PrimaryButton}" Content="Import Data From Jolpica" Click="Button_Click"></Button>
                        </Grid>

                        <TextBlock Text="Points System" FontSize="16" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" Margin="0,30,0,15"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="400"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Label Grid.Row="0" Grid.Column="0" Content="Points For Fastest Lap (Top 10):" VerticalAlignment="Center" Margin="0,0,0,15"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Name="PointsForFastestLapTextBox" Style="{StaticResource ModernTextBox}" Margin="0,0,0,15"/>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <DataGrid Grid.Column="0" Name="PointsSystemDataGrid" 
                                      Style="{StaticResource ModernDataGrid}"
                                      Height="300"
                                      Margin="0,0,10,0">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Position" Binding="{Binding Position}" Width="100" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="Points" Binding="{Binding Points}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <StackPanel Grid.Column="1" VerticalAlignment="Top">
                                <Button Content="Add Position" Style="{StaticResource SecondaryButton}" Click="AddPointsPosition_Click" Margin="0,0,0,10" Width="120"/>
                                <Button Content="Remove Position" Style="{StaticResource SecondaryButton}" Click="RemovePointsPosition_Click" Width="120"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Races Tab -->
            <TabItem Header="RACES" Style="{StaticResource ModernTabItem}">
                <Grid Margin="30,20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Race Calendar" FontSize="18" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,20"/>

                    <DataGrid Grid.Row="1" Name="RacesDataGrid" 
                              Style="{StaticResource ModernDataGrid}"
                              SelectionChanged="RacesDataGrid_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding RaceId}" Width="50"/>
                            <DataGridTextColumn Header="Race Name" Binding="{Binding RaceName}" Width="200"/>
                            <DataGridTextColumn Header="Short Name" Binding="{Binding RaceShortName}" Width="150"/>
                            <DataGridTextColumn Header="Date" Binding="{Binding RaceDate}" Width="120"/>
                            <DataGridTextColumn Header="Circuit" Binding="{Binding Circuit}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                        <Button Content="Add Race" Style="{StaticResource SecondaryButton}" Click="AddRace_Click" Margin="0,0,10,0"/>
                        <Button Content="Edit Race" Style="{StaticResource SecondaryButton}" Click="EditRace_Click" Margin="0,0,10,0"/>
                        <Button Content="Add Sprint Race" Style="{StaticResource SecondaryButton}" Click="AddSprintRace_Click" Margin="0,0,10,0"/>
                        <Button Content="Remove Race" Style="{StaticResource SecondaryButton}" Click="RemoveRace_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Drivers Tab -->
            <TabItem Header="DRIVERS" Style="{StaticResource ModernTabItem}">
                <Grid Margin="30,20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Driver Database" FontSize="18" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,20"/>

                    <DataGrid Grid.Row="1" Name="DriversDataGrid" 
                              Style="{StaticResource ModernDataGrid}"
                              SelectionChanged="DriversDataGrid_SelectionChanged"
                              AutoGenerateColumns="False"
                              CanUserSortColumns="True">
                        <DataGrid.ContextMenu>
                            <ContextMenu Name="DriversContextMenu" Opened="DriversContextMenu_Opened">
                                <MenuItem Header="Remove Malus From Team" Name="RemoveMalusMenuItem">
                                    <!-- Team submenu items will be populated dynamically -->
                                </MenuItem>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding DriverId}" Width="100" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="160" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Nat" Binding="{Binding Nationality}" Width="60" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Born" Binding="{Binding YearOfBirth}" Width="60" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Rep" Binding="{Binding Reputation}" Width="80" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Aggr" Binding="{Binding Aggression, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="50" SortDirection="Descending"/>
                            <DataGridTextColumn Header="AvFM" Binding="{Binding AvoidanceForcedMistakes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="70"/>
                            <DataGridTextColumn Header="AvM" Binding="{Binding AvoidanceMistakes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="70"/>
                            <DataGridTextColumn Header="Blue" Binding="{Binding BlueFlagConceding, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="70"/>
                            <DataGridTextColumn Header="Cons" Binding="{Binding Consistency, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="70"/>
                            <DataGridTextColumn Header="Def" Binding="{Binding Defending, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="70"/>
                            <DataGridTextColumn Header="Fuel" Binding="{Binding FuelManagement, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="70"/>
                            <DataGridTextColumn Header="Qual" Binding="{Binding QualifyingSkill, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="70"/>
                            <DataGridTextColumn Header="Race" Binding="{Binding RaceSkill, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="70"/>
                            <DataGridTextColumn Header="Stam" Binding="{Binding Stamina, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="70"/>
                            <DataGridTextColumn Header="Start" Binding="{Binding StartReactions, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="70"/>
                            <DataGridTextColumn Header="Tyre" Binding="{Binding TyreManagement, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="70"/>
                            <DataGridTextColumn Header="VehR" Binding="{Binding VehicleReliability, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="70"/>
                            <DataGridTextColumn Header="WTC" Binding="{Binding WeatherTyreChanges, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="70"/>
                            <DataGridTextColumn Header="Wet" Binding="{Binding WetSkill, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="70"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                        <Button Content="Add Driver" Style="{StaticResource SecondaryButton}" Click="AddDriver_Click" Margin="0,0,10,0"/>
                        <Button Content="Edit Driver" Style="{StaticResource SecondaryButton}" Click="EditDriver_Click" Margin="0,0,10,0"/>
                        <Button Content="Remove Driver" Style="{StaticResource SecondaryButton}" Click="RemoveDriver_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Teams Tab -->
            <TabItem Header="TEAMS AND LIVERIES" Style="{StaticResource ModernTabItem}">
                <Grid Margin="30,20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Team Entries" FontSize="18" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,20"/>

                    <DataGrid Grid.Row="1" Name="TeamsDataGrid" 
                              Style="{StaticResource ModernDataGrid}"
                              SelectionChanged="TeamsDataGrid_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="" Width="40">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Rectangle Width="24" 
                                                   Height="24" 
                                                   RadiusX="2"
                                                   RadiusY="2"
                                                   Margin="8,2"
                                                   Stroke="#666666"
                                                   StrokeThickness="1"
                                                   Fill="{Binding Color, Converter={StaticResource StringToBrushConverter}}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="ID" Binding="{Binding TeamId}" Width="100"/>
                            <DataGridTextColumn Header="Team Name" Binding="{Binding TeamName}" Width="200"/>
                            <DataGridTextColumn Header="Principal" Binding="{Binding TeamPrincipal}" Width="150"/>
                            <DataGridTextColumn Header="Driver 1" Binding="{Binding Driver1Contract.DriverId}" Width="120"/>
                            <DataGridTextColumn Header="Driver 2" Binding="{Binding Driver2Contract.DriverId}" Width="120"/>
                            <DataGridTextColumn Header="Reputation" Binding="{Binding Reputation}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                        <Button Content="Add Team" Style="{StaticResource SecondaryButton}" Click="AddTeam_Click" Margin="0,0,10,0"/>
                        <Button Content="Edit Team" Style="{StaticResource SecondaryButton}" Click="EditTeam_Click" Margin="0,0,10,0"/>
                        <Button Content="Edit Liveries" Style="{StaticResource SecondaryButton}" Click="EditLiveries_Click" Margin="0,0,10,0"/>
                        <Button Content="Remove Team" Style="{StaticResource SecondaryButton}" Click="RemoveTeam_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="LIVERY CREATOR" Style="{StaticResource ModernTabItem}">
                <controls:LiveryCreatorControl />
            </TabItem>

            <TabItem Header="HELMET EDITOR" Style="{StaticResource ModernTabItem}">
                <helmet:HelmetSticker3DControl />
            </TabItem>

            <!-- Absences Tab -->
            <TabItem Header="ABSENCES" Style="{StaticResource ModernTabItem}">
                <Grid Margin="30,20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Driver Absences and Substitutions" FontSize="18" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,20"/>

                    <DataGrid Grid.Row="1" Name="AbsencesDataGrid" 
                              Style="{StaticResource ModernDataGrid}"
                              SelectionChanged="AbsencesDataGrid_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Race ID" Binding="{Binding RaceId}" Width="80"/>
                            <DataGridTextColumn Header="Team" Binding="{Binding TeamId}" Width="150"/>
                            <DataGridTextColumn Header="Driver Out" Binding="{Binding DriverOut}" Width="150"/>
                            <DataGridTextColumn Header="Driver In" Binding="{Binding DriverIn}" Width="150"/>
                            <DataGridTextColumn Header="Has Chain" Binding="{Binding HasChainedAbsence}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                        <Button Content="Add Absence" Style="{StaticResource SecondaryButton}" Click="AddAbsence_Click" Margin="0,0,10,0"/>
                        <Button Content="Edit Absence" Style="{StaticResource SecondaryButton}" Click="EditAbsence_Click" Margin="0,0,10,0"/>
                        <Button Content="Remove Absence" Style="{StaticResource SecondaryButton}" Click="RemoveAbsence_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Scenarios Tab -->
            <TabItem Header="SCENARIOS" Style="{StaticResource ModernTabItem}">
                <Grid Margin="30,20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Scenarios" FontSize="18" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,20"/>

                    <DataGrid Grid.Row="1" Name="ScenariosDataGrid"
                              Style="{StaticResource ModernDataGrid}"
                              AutoGenerateColumns="False"
                              SelectionMode="Single"
                              CanUserSortColumns="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="200" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Picture" Binding="{Binding PictureUrl}" Width="200" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Game File" Binding="{Binding GameFile}" Width="200" IsReadOnly="True"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                        <Button Content="Add Scenario"      Style="{StaticResource SecondaryButton}" Click="AddScenario_Click"   Margin="0,0,10,0"/>
                        <Button Content="Edit Scenario"     Style="{StaticResource SecondaryButton}" Click="EditScenario_Click"  Margin="0,0,10,0"/>
                        <Button Content="⚙ Build Save..."   Style="{StaticResource PrimaryButton}"  Click="BuildScenario_Click"  Margin="0,0,10,0"/>
                        <Button Content="Remove Scenario"   Style="{StaticResource SecondaryButton}" Click="RemoveScenario_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Static Assets Tab -->
            <TabItem Header="STATIC ASSETS" Style="{StaticResource ModernTabItem}">
                <Grid Margin="30,20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Static Assets Folder" FontSize="18" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,20"/>

                    <!-- Source Folder Selection -->
                    <Grid Grid.Row="1" Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="Source Folder:" VerticalAlignment="Center" Margin="0,0,15,0" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBox Grid.Column="1" Name="StaticAssetsFolderTextBox" IsReadOnly="True" Style="{StaticResource ModernTextBox}" Margin="0,0,10,0"/>
                        <Button Grid.Column="2" Content="Browse..." Style="{StaticResource SecondaryButton}" Click="BrowseStaticAssetsFolder_Click" Padding="15,8"/>
                    </Grid>

                    <!-- Files Grid -->
                    <DataGrid Grid.Row="2" Name="StaticAssetsDataGrid" 
                              Style="{StaticResource ModernDataGrid}"
                              AutoGenerateColumns="False"
                              SelectionMode="Extended"
                              CanUserSortColumns="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="File Path" Binding="{Binding FilePath}" Width="*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Size" Binding="{Binding SizeFormatted}" Width="100" IsReadOnly="True"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                        <Button Content="Add Files" Style="{StaticResource SecondaryButton}" Click="AddStaticAssetFiles_Click" Margin="0,0,10,0"/>
                        <Button Content="Remove Selected" Style="{StaticResource SecondaryButton}" Click="RemoveStaticAssetFiles_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>

        </TabControl>

        <!-- Footer -->
        <Border Grid.Row="2" Background="#0D0D0D" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="20,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Ready" Name="StatusTextBlock" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="GENERATE TEST SAVE FILE" Style="{StaticResource SecondaryButton}" Click="GenerateTestSave_Click" Padding="30,12" Margin="5,0,0,0" Width="220" ToolTip="Generate a save file to test the season pack on Rewind GP without exporting the whole thing."/>
                <Button Grid.Column="2" Content="EXPORT SEASON PACK" Style="{StaticResource PrimaryButton}" Click="ExportSeasonPack_Click" Padding="30,12" Margin="5,0,0,0" Width="195" ToolTip="Export the season pack in the format that could be installed in Rewind GP"/>
            </Grid>
        </Border>
    </Grid>
</Window>
