<UserControl x:Class="AMS2ChEd.SeasonPackEditor.HelmetEditor.Controls.HelmetSticker3DControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:hx="clr-namespace:HelixToolkit.Wpf.SharpDX;assembly=HelixToolkit.SharpDX.Core.Wpf"
             Background="#1A1A1A"
             FontFamily="Bahnschrift, Segoe UI, Arial"
             Foreground="#E8E8E8">

    <UserControl.Resources>
        <SolidColorBrush x:Key="Accent"    Color="#D4A017"/>
        <SolidColorBrush x:Key="SidebarBg" Color="#1C1C1C"/>
        <SolidColorBrush x:Key="PanelBg"   Color="#222222"/>
        <SolidColorBrush x:Key="Border"    Color="#333333"/>

        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background"      Value="#2E2E2E"/>
            <Setter Property="Foreground"      Value="#DDDDDD"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="8,6"/>
            <Setter Property="FontSize"        Value="10"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="2" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3A3A3A"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#222222"/>
                                <Setter Property="Foreground" Value="#555555"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Zone slot style -->
        <Style x:Key="ZoneLabel" TargetType="TextBlock">
            <Setter Property="FontSize"     Value="9"/>
            <Setter Property="FontWeight"   Value="Bold"/>
            <Setter Property="Foreground"   Value="#777777"/>
            <Setter Property="Margin"       Value="0,0,0,4"/>
        </Style>

        <Style x:Key="ZoneFile" TargetType="TextBlock">
            <Setter Property="FontSize"          Value="9"/>
            <Setter Property="Foreground"        Value="#555555"/>
            <Setter Property="TextTrimming"      Value="CharacterEllipsis"/>
            <Setter Property="Margin"            Value="0,0,0,10"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ 3D VIEWPORT + SIDEBAR ═══════════════════════════════════════ -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="200"/>
            </Grid.ColumnDefinitions>

            <!-- 3D Viewport -->
            <Border Grid.Column="0" Background="#101010"
                    BorderBrush="{StaticResource Border}" BorderThickness="0,0,1,0">
                <hx:Viewport3DX x:Name="Viewport"
                                Camera="{Binding Camera}"
                                EffectsManager="{Binding EffectsManager}"
                                BackgroundColor="#404040"
                                ShowCoordinateSystem="True"
                                IsRotationEnabled="True"
                                IsPanEnabled="True"
                                IsZoomEnabled="True"
                                RotationSensitivity="1.5"
                                ZoomSensitivity="1.0"
                                CameraRotationMode="Trackball">
                    <hx:DirectionalLight3D Direction="-1,-1,-2" Color="White" />
                    <hx:DirectionalLight3D Direction="1,1,-1"  Color="White" />
                    <hx:AmbientLight3D     Color="#666666" />
                </hx:Viewport3DX>
            </Border>

            <!-- Right Sidebar -->
            <Border Grid.Column="1" Background="{StaticResource SidebarBg}"
                    BorderBrush="{StaticResource Border}" BorderThickness="1,0,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12,12">

                        <!-- ── Helmet Shape ── -->
                        <TextBlock Text="HELMET SHAPE" Style="{StaticResource ZoneLabel}"/>
                        <ComboBox x:Name="HelmetCombo"
                                  Background="#2E2E2E" Foreground="#DDDDDD"
                                  BorderBrush="#444444" FontSize="10"
                                  Margin="0,0,0,4"
                                  SelectionChanged="HelmetCombo_SelectionChanged"/>

                        <Separator Background="#333333" Margin="0,4,0,12"/>

                        <!-- ── Zone Textures ── -->
                        <TextBlock Text="ZONE TEXTURES" Style="{StaticResource ZoneLabel}"/>

                        <!-- Left -->
                        <DockPanel Margin="0,0,0,2">
                            <TextBlock Text="LEFT" FontSize="9" Foreground="#999999"
                                       VerticalAlignment="Center" Width="36"/>
                            <Button Content="Load…" DockPanel.Dock="Right"
                                    Click="LoadLeft_Click"
                                    Style="{StaticResource ActionButton}"
                                    Padding="6,4"/>
                            <Button Content="✕" DockPanel.Dock="Right"
                                    Click="ClearLeft_Click"
                                    Style="{StaticResource ActionButton}"
                                    Padding="4,4" Margin="2,0,0,0"
                                    Foreground="#AA4444"/>
                            <TextBlock x:Name="LeftFileLabel" Text="—"
                                       Style="{StaticResource ZoneFile}"
                                       Margin="6,0,4,0" VerticalAlignment="Center"/>
                        </DockPanel>
                        <StackPanel Orientation="Horizontal" Margin="36,0,0,8">
                            <CheckBox x:Name="LeftFlipU" Content="Flip H" FontSize="9"
                                      Foreground="#777777" Margin="0,0,8,0"/>
                            <CheckBox x:Name="LeftFlipV" Content="Flip V" FontSize="9"
                                      Foreground="#777777"/>
                        </StackPanel>


                        <!-- Right -->
                        <DockPanel Margin="0,0,0,2">
                            <TextBlock Text="RIGHT" FontSize="9" Foreground="#999999"
                                       VerticalAlignment="Center" Width="36"/>
                            <Button Content="Load…" DockPanel.Dock="Right"
                                    Click="LoadRight_Click"
                                    Style="{StaticResource ActionButton}"
                                    Padding="6,4"/>
                            <Button Content="✕" DockPanel.Dock="Right"
                                    Click="ClearRight_Click"
                                    Style="{StaticResource ActionButton}"
                                    Padding="4,4" Margin="2,0,0,0"
                                    Foreground="#AA4444"/>
                            <TextBlock x:Name="RightFileLabel" Text="—"
                                       Style="{StaticResource ZoneFile}"
                                       Margin="6,0,4,0" VerticalAlignment="Center"/>
                        </DockPanel>
                        <StackPanel Orientation="Horizontal" Margin="36,0,0,8">
                            <CheckBox x:Name="RightFlipU" Content="Flip H" FontSize="9"
                                      Foreground="#777777" Margin="0,0,8,0"/>
                            <CheckBox x:Name="RightFlipV" Content="Flip V" FontSize="9"
                                      Foreground="#777777"/>
                        </StackPanel>


                        <!-- Front -->
                        <DockPanel Margin="0,0,0,2">
                            <TextBlock Text="FRONT" FontSize="9" Foreground="#999999"
                                       VerticalAlignment="Center" Width="36"/>
                            <Button Content="Load…" DockPanel.Dock="Right"
                                    Click="LoadFront_Click"
                                    Style="{StaticResource ActionButton}"
                                    Padding="6,4"/>
                            <Button Content="✕" DockPanel.Dock="Right"
                                    Click="ClearFront_Click"
                                    Style="{StaticResource ActionButton}"
                                    Padding="4,4" Margin="2,0,0,0"
                                    Foreground="#AA4444"/>
                            <TextBlock x:Name="FrontFileLabel" Text="—"
                                       Style="{StaticResource ZoneFile}"
                                       Margin="6,0,4,0" VerticalAlignment="Center"/>
                        </DockPanel>

                        <!-- Back -->
                        <DockPanel Margin="0,0,0,2">
                            <TextBlock Text="BACK" FontSize="9" Foreground="#999999"
                                       VerticalAlignment="Center" Width="36"/>
                            <Button Content="Load…" DockPanel.Dock="Right"
                                    Click="LoadBack_Click"
                                    Style="{StaticResource ActionButton}"
                                    Padding="6,4"/>
                            <Button Content="✕" DockPanel.Dock="Right"
                                    Click="ClearBack_Click"
                                    Style="{StaticResource ActionButton}"
                                    Padding="4,4" Margin="2,0,0,0"
                                    Foreground="#AA4444"/>
                            <TextBlock x:Name="BackFileLabel" Text="—"
                                       Style="{StaticResource ZoneFile}"
                                       Margin="6,0,4,0" VerticalAlignment="Center"/>
                        </DockPanel>

                        <!-- Top -->
                        <DockPanel Margin="0,0,0,2">
                            <TextBlock Text="TOP" FontSize="9" Foreground="#999999"
                                       VerticalAlignment="Center" Width="36"/>
                            <Button Content="Load…" DockPanel.Dock="Right"
                                    Click="LoadTop_Click"
                                    Style="{StaticResource ActionButton}"
                                    Padding="6,4"/>
                            <Button Content="✕" DockPanel.Dock="Right"
                                    Click="ClearTop_Click"
                                    Style="{StaticResource ActionButton}"
                                    Padding="4,4" Margin="2,0,0,0"
                                    Foreground="#AA4444"/>
                            <TextBlock x:Name="TopFileLabel" Text="—"
                                       Style="{StaticResource ZoneFile}"
                                       Margin="6,0,4,0" VerticalAlignment="Center"/>
                        </DockPanel>

                        <Separator Background="#333333" Margin="0,4,0,12"/>

                        <!-- ── Bake ── -->
                        <Button x:Name="BakeButton"
                                Content="▶  BAKE"
                                Click="Bake_Click"
                                Background="#3A5F0B" Foreground="#FFFFFF"
                                BorderThickness="0" Padding="8,10"
                                FontSize="12" FontWeight="Bold"
                                Cursor="Hand" Margin="0,0,0,6"
                                IsEnabled="False"/>

                        <TextBlock x:Name="BakeStatusLabel"
                                   Text="" FontSize="9"
                                   Foreground="#888888"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,0"/>

                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- ═══ BOTTOM BAR ══════════════════════════════════════════════════ -->
        <Border Grid.Row="1" Background="{StaticResource PanelBg}"
                BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0"
                Padding="15,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" VerticalAlignment="Center"
                           FontSize="10" Foreground="#555555"
                           Text="Drag to rotate  ·  Scroll to zoom  ·  Middle-drag to pan"/>

                <Button Grid.Column="1"
                        Content="Export PNG…"
                        Click="Export_Click"
                        Style="{StaticResource ActionButton}"
                        IsEnabled="False"
                        x:Name="ExportButton"
                        Padding="12,8"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
