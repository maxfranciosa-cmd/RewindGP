<Window x:Class="AMS2ChEd.TeamSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Team" 
        Height="700" Width="800"
        WindowStartupLocation="CenterScreen"
        Background="#1a1a1a"
        ResizeMode="CanResize">

    <Window.Resources>
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#c41e3a"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#d32f2f"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#555555"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#666666"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DriverCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#2a2a2a"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#666666"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DriverCardSelectedStyle" TargetType="Border" BasedOn="{StaticResource DriverCardStyle}">
            <Setter Property="BorderBrush" Value="#c41e3a"/>
            <Setter Property="BorderThickness" Value="3"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Background="#0d0d0d" Margin="20">
            <TextBlock Text="SELECT ROLE TO REPLACE" 
                       FontSize="32" 
                       FontWeight="Bold" 
                       Foreground="White" 
                       HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- Teams List + Free Agents -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="20">
            <StackPanel>

                <!-- Teams -->
                <ItemsControl x:Name="TeamsItemsControl">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,0,0,20">
                                <!-- Team Name with Color Accent -->
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Team Color Strip -->
                                    <Border Grid.Column="0"
                                            Width="5"
                                            Background="{Binding TeamColor}"
                                            CornerRadius="2"
                                            Margin="0,0,10,0"/>

                                    <TextBlock Grid.Column="1"
                                              Text="{Binding TeamName}" 
                                              FontSize="20" 
                                              FontWeight="Bold" 
                                              Foreground="#c41e3a"
                                              VerticalAlignment="Center"/>
                                </Grid>

                                <!-- Drivers Grid -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Driver 1 -->
                                    <Border Grid.Column="0" 
                                            x:Name="Driver1Border"
                                            MouseLeftButtonDown="DriverCard_Click"
                                            Tag="{Binding Driver1}">
                                        <Border.Style>
                                            <Style TargetType="Border" BasedOn="{StaticResource DriverCardStyle}">
                                            </Style>
                                        </Border.Style>
                                        <Grid Height="120">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="100"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="15,0,0,0">
                                                <TextBlock Text="{Binding Driver1.RoleName}" 
                                                          FontSize="12" 
                                                          Foreground="#aaaaaa"
                                                          Margin="0,5,0,0"/>
                                                <TextBlock Text="{Binding Driver1.Name}" 
                                                          FontSize="16" 
                                                          FontWeight="Bold" 
                                                          Foreground="White"/>
                                                <TextBlock Text="{Binding Driver1.Nationality}" 
                                                          FontSize="12" 
                                                          Foreground="#aaaaaa"
                                                          Margin="0,5,0,0"/>
                                                <TextBlock Text="{Binding Driver1.Number, StringFormat='#{0}'}" 
                                                          FontSize="14" 
                                                          FontWeight="Bold"
                                                          Foreground="#c41e3a"
                                                          Margin="0,5,0,0"/>
                                            </StackPanel>

                                            <!-- Driver Photo -->
                                            <Border Grid.Column="1" 
                                                   Background="#1a1a1a" 
                                                   Margin="10"
                                                   CornerRadius="5"
                                                   ClipToBounds="True">
                                                <Grid>
                                                    <Image Stretch="Uniform">
                                                        <Image.Style>
                                                            <Style TargetType="Image">
                                                                <Setter Property="Source" Value="{Binding Driver1.PhotoUrl}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Driver1.PhotoUrl}" Value="{x:Null}">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Driver1.PhotoUrl}" Value="">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Driver1.PhotoUrl}" Value="N/A">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Image.Style>
                                                    </Image>
                                                    <Grid>
                                                        <Grid.Style>
                                                            <Style TargetType="Grid">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Driver1.PhotoUrl}" Value="{x:Null}">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Driver1.PhotoUrl}" Value="">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Driver1.PhotoUrl}" Value="N/A">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Grid.Style>
                                                        <Viewbox Width="40" Height="40">
                                                            <Canvas Width="24" Height="24">
                                                                <Path Fill="#555555" Data="M12,4A4,4 0 0,1 16,8A4,4 0 0,1 12,12A4,4 0 0,1 8,8A4,4 0 0,1 12,4M12,14C16.42,14 20,15.79 20,18V20H4V18C4,15.79 7.58,14 12,14Z"/>
                                                            </Canvas>
                                                        </Viewbox>
                                                    </Grid>
                                                </Grid>
                                            </Border>
                                        </Grid>
                                    </Border>

                                    <!-- Driver 2 -->
                                    <Border Grid.Column="1" 
                                            x:Name="Driver2Border"
                                            MouseLeftButtonDown="DriverCard_Click"
                                            Tag="{Binding Driver2}">
                                        <Border.Style>
                                            <Style TargetType="Border" BasedOn="{StaticResource DriverCardStyle}">
                                            </Style>
                                        </Border.Style>
                                        <Grid Height="120">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="100"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="15,0,0,0">
                                                <TextBlock Text="{Binding Driver2.RoleName}" 
                                                          FontSize="12" 
                                                          Foreground="#aaaaaa"
                                                          Margin="0,5,0,0"/>
                                                <TextBlock Text="{Binding Driver2.Name}" 
                                                          FontSize="16" 
                                                          FontWeight="Bold" 
                                                          Foreground="White"/>
                                                <TextBlock Text="{Binding Driver2.Nationality}" 
                                                          FontSize="12" 
                                                          Foreground="#aaaaaa"
                                                          Margin="0,5,0,0"/>
                                                <TextBlock Text="{Binding Driver2.Number, StringFormat='#{0}'}" 
                                                          FontSize="14" 
                                                          FontWeight="Bold"
                                                          Foreground="#c41e3a"
                                                          Margin="0,5,0,0"/>
                                            </StackPanel>

                                            <!-- Driver Photo -->
                                            <Border Grid.Column="1" 
                                                   Background="#1a1a1a" 
                                                   Margin="10"
                                                   CornerRadius="5"
                                                   ClipToBounds="True">
                                                <Grid>
                                                    <Image Stretch="Uniform">
                                                        <Image.Style>
                                                            <Style TargetType="Image">
                                                                <Setter Property="Source" Value="{Binding Driver2.PhotoUrl}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Driver2.PhotoUrl}" Value="{x:Null}">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Driver2.PhotoUrl}" Value="">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Driver2.PhotoUrl}" Value="N/A">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Image.Style>
                                                    </Image>
                                                    <Grid>
                                                        <Grid.Style>
                                                            <Style TargetType="Grid">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Driver2.PhotoUrl}" Value="{x:Null}">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Driver2.PhotoUrl}" Value="">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Driver2.PhotoUrl}" Value="N/A">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Grid.Style>
                                                        <Viewbox Width="40" Height="40">
                                                            <Canvas Width="24" Height="24">
                                                                <Path Fill="#555555" Data="M12,4A4,4 0 0,1 16,8A4,4 0 0,1 12,12A4,4 0 0,1 8,8A4,4 0 0,1 12,4M12,14C16.42,14 20,15.79 20,18V20H4V18C4,15.79 7.58,14 12,14Z"/>
                                                            </Canvas>
                                                        </Viewbox>
                                                    </Grid>
                                                </Grid>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Free Agents Section -->
                <StackPanel x:Name="FreeAgentsSection" Visibility="Collapsed" Margin="0,10,0,0">

                    <!-- Divider + Header -->
                    <Grid Margin="5,10,5,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Rectangle Grid.Column="0" Height="1" Fill="#444444" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1"
                                   Text="FREE AGENTS"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Foreground="#888888"
                                   Margin="12,0"/>
                        <Rectangle Grid.Column="2" Height="1" Fill="#444444" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Free Agent Cards — two per row via WrapPanel -->
                    <ItemsControl x:Name="FreeAgentsItemsControl">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="2"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border MouseLeftButtonDown="DriverCard_Click"
                                        Tag="{Binding}"
                                        Style="{StaticResource DriverCardStyle}">
                                    <Grid Height="120">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="100"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="15,0,0,0">
                                            <TextBlock Text="{Binding RoleName}"
                                                      FontSize="12"
                                                      Foreground="#888888"
                                                      Margin="0,5,0,0"/>
                                            <TextBlock Text="{Binding Name}"
                                                      FontSize="16"
                                                      FontWeight="Bold"
                                                      Foreground="White"/>
                                            <TextBlock Text="{Binding Nationality}"
                                                      FontSize="12"
                                                      Foreground="#aaaaaa"
                                                      Margin="0,5,0,0"/>
                                        </StackPanel>

                                        <!-- Driver Photo -->
                                        <Border Grid.Column="1"
                                               Background="#1a1a1a"
                                               Margin="10"
                                               CornerRadius="5"
                                               ClipToBounds="True">
                                            <Grid>
                                                <Image Stretch="Uniform">
                                                    <Image.Style>
                                                        <Style TargetType="Image">
                                                            <Setter Property="Source" Value="{Binding PhotoUrl}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding PhotoUrl}" Value="{x:Null}">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding PhotoUrl}" Value="">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding PhotoUrl}" Value="N/A">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Image.Style>
                                                </Image>
                                                <Grid>
                                                    <Grid.Style>
                                                        <Style TargetType="Grid">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding PhotoUrl}" Value="{x:Null}">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding PhotoUrl}" Value="">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding PhotoUrl}" Value="N/A">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Grid.Style>
                                                    <Viewbox Width="40" Height="40">
                                                        <Canvas Width="24" Height="24">
                                                            <Path Fill="#555555" Data="M12,4A4,4 0 0,1 16,8A4,4 0 0,1 12,12A4,4 0 0,1 8,8A4,4 0 0,1 12,4M12,14C16.42,14 20,15.79 20,18V20H4V18C4,15.79 7.58,14 12,14Z"/>
                                                        </Canvas>
                                                    </Viewbox>
                                                </Grid>
                                            </Grid>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Center"
                    Margin="20">
            <Button Content="CONFIRM" 
                    Width="150"
                    Margin="0,0,10,0"
                    Style="{StaticResource MenuButtonStyle}"
                    Click="ConfirmButton_Click"/>
            <Button Content="BACK" 
                    Width="150"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Click="BackButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
