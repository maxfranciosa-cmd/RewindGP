<!--Historical Standings Window - 1990s F1 Broadcast Style-->
<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        mc:Ignorable="d" 
        x:Class="AMS2ChEd.Views.HistoricalStandingsWindow"
        Title="Historical Championship Standings" 
        Height="800" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#1a1a1a">

    <Window.Resources>
        <!-- Year Selector Button Style -->
        <Style x:Key="YearButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="#2a2a2a"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3a3a3a"/>
                    <Setter Property="BorderBrush" Value="#c41e3a"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Selected Year Button Style -->
        <Style x:Key="SelectedYearButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource YearButtonStyle}">
            <Setter Property="Background" Value="#dc143c"/>
            <Setter Property="BorderBrush" Value="#c41e3a"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#b01030"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Standings Header Style -->
        <Style x:Key="StandingsHeaderStyle" TargetType="{x:Type Border}">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#dc143c" Offset="0"/>
                        <GradientStop Color="#b01030" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Height" Value="50"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#dc143c" BlurRadius="10" ShadowDepth="0" Opacity="0.4"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Standing Item Style -->
        <Style x:Key="StandingItemStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#222222"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Height" Value="40"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsEven}" Value="True">
                    <Setter Property="Background" Value="#0f0f0f"/>
                </DataTrigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1a1a1a"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Team Color Strip Style -->
        <Style x:Key="TeamColorStyle" TargetType="{x:Type Border}">
            <Setter Property="Width" Value="5"/>
            <Setter Property="CornerRadius" Value="2"/>
            <Setter Property="Margin" Value="0,0,15,0"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <Border Grid.Row="0" 
                Background="#0a0a0a" 
                BorderBrush="#dc143c" 
                BorderThickness="0,0,0,2"
                Padding="20">
            <Grid>
                <TextBlock Text="HISTORICAL CHAMPIONSHIP STANDINGS" 
                           FontSize="24" 
                           FontWeight="Bold" 
                           Foreground="White"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Year Selector -->
        <Border Grid.Row="1"
                Background="#0a0a0a"
                BorderBrush="#222222"
                BorderThickness="0,0,0,1"
                Padding="20,15">
            <StackPanel>
                <TextBlock Text="SELECT SEASON:" 
                           FontSize="12" 
                           FontWeight="SemiBold"
                           Foreground="#999999"
                           Margin="0,0,0,10"/>
                <ItemsControl x:Name="YearSelector">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Content="{Binding Year}"
                                    Tag="{Binding Year}"
                                    Click="YearButton_Click">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource YearButtonStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                <Setter Property="Background" Value="#dc143c"/>
                                                <Setter Property="BorderBrush" Value="#c41e3a"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <!-- Standings Display -->
        <Grid Grid.Row="2" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Driver Standings -->
            <Border Grid.Column="0" 
                    Background="#0a0a0a" 
                    BorderBrush="#dc143c" 
                    BorderThickness="2"
                    CornerRadius="0">
                <Border.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="10" ShadowDepth="4" Opacity="0.5"/>
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Border Grid.Row="0" 
                            Style="{StaticResource StandingsHeaderStyle}">
                        <TextBlock Text="DRIVERS' CHAMPIONSHIP" 
                                   FontSize="16" 
                                   FontWeight="Bold" 
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <!-- Standings List -->
                    <ScrollViewer Grid.Row="1" 
                                  VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="HistoricalDriverStandingsItems">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource StandingItemStyle}">
                                        <Grid Margin="15,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="35"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="70"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Position -->
                                            <TextBlock Grid.Column="0" 
                                                      Text="{Binding Position, StringFormat=\{0\}.}"
                                                      FontSize="14"
                                                      FontWeight="Bold"
                                                      Foreground="#999999"
                                                      VerticalAlignment="Center"/>

                                            <!-- Driver Name -->
                                            <TextBlock Grid.Column="1" 
                                                      Text="{Binding DriverName}"
                                                      FontSize="14"
                                                      Foreground="White"
                                                      VerticalAlignment="Center"/>

                                            <!-- Team Name -->
                                            <TextBlock Grid.Column="2" 
                                                      Text="{Binding TeamName}"
                                                      FontSize="12"
                                                      Foreground="#666666"
                                                      VerticalAlignment="Center"
                                                      Margin="10,0"/>

                                            <!-- Points -->
                                            <TextBlock Grid.Column="3" 
                                                      Text="{Binding Points, StringFormat=\{0\}pt}"
                                                      FontSize="15"
                                                      FontWeight="SemiBold"
                                                      Foreground="#666666"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Right"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Constructor Standings -->
            <Border Grid.Column="2" 
                    Background="#0a0a0a" 
                    BorderBrush="#dc143c" 
                    BorderThickness="2"
                    CornerRadius="0">
                <Border.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="10" ShadowDepth="4" Opacity="0.5"/>
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Border Grid.Row="0" 
                            Style="{StaticResource StandingsHeaderStyle}">
                        <TextBlock Text="CONSTRUCTORS' CHAMPIONSHIP" 
                                   FontSize="16" 
                                   FontWeight="Bold" 
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <!-- Standings List -->
                    <ScrollViewer Grid.Row="1" 
                                  VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="HistoricalConstructorStandingsItems">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource StandingItemStyle}">
                                        <Grid Margin="15,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="35"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="70"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Position -->
                                            <TextBlock Grid.Column="0" 
                                                      Text="{Binding Position, StringFormat=\{0\}.}"
                                                      FontSize="14"
                                                      FontWeight="Bold"
                                                      Foreground="#999999"
                                                      VerticalAlignment="Center"/>

                                            <!-- Team Name -->
                                            <TextBlock Grid.Column="2" 
                                                      Text="{Binding TeamName}"
                                                      FontSize="14"
                                                      Foreground="White"
                                                      VerticalAlignment="Center"/>

                                            <!-- Points -->
                                            <TextBlock Grid.Column="3" 
                                                      Text="{Binding Points, StringFormat=\{0\}pt}"
                                                      FontSize="15"
                                                      FontWeight="SemiBold"
                                                      Foreground="#666666"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Right"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
