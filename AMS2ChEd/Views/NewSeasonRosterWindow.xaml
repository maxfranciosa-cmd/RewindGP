<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="AMS2ChEd.Views.NewSeasonRosterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Season Preview" 
        Height="900" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#f5f5dc"
        ResizeMode="NoResize">

    <Window.Resources>
        <Style x:Key="ButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#c41e3a"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="Width" Value="220"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#d32f2f"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Border Background="White" 
                BorderBrush="#2c2c2c" 
                BorderThickness="3"
                Margin="30"
                CornerRadius="2">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="5" Opacity="0.4"/>
            </Border.Effect>

            <Grid Margin="30">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                    <TextBlock Text="MOTORSPORT GAZETTE"
                               FontSize="32" 
                               FontWeight="Black" 
                               FontFamily="Times New Roman"
                               Foreground="#2c2c2c"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,5"/>

                    <Rectangle Height="3" Fill="#2c2c2c" Margin="0,0,0,5"/>
                    <Rectangle Height="1" Fill="#666666" Margin="0,0,0,5"/>

                    <TextBlock x:Name="DateText"
                               FontSize="11" 
                               FontFamily="Times New Roman"
                               Foreground="#666666"
                               HorizontalAlignment="Center"
                               Margin="0,5,0,0"/>
                </StackPanel>

                <Border Grid.Row="1" 
                        Background="#1976d2" 
                        Padding="10,5"
                        Margin="0,0,0,15">
                    <TextBlock Text="SEASON PREVIEW"
                               FontSize="14" 
                               FontWeight="Bold" 
                               FontFamily="Times New Roman"
                               Foreground="White"
                               HorizontalAlignment="Center"/>
                </Border>

                <TextBlock x:Name="HeadlineText"
                           Grid.Row="2"
                           FontSize="24" 
                           FontWeight="Bold" 
                           FontFamily="Times New Roman"
                           Foreground="#2c2c2c"
                           TextWrapping="Wrap"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           Margin="0,0,0,20"/>

                <ScrollViewer Grid.Row="3" 
                              VerticalScrollBarVisibility="Auto"
                              Margin="20,0">
                    <StackPanel>
                        <TextBlock x:Name="IntroText"
                                   FontSize="14"
                                   FontFamily="Times New Roman"
                                   Foreground="#2c2c2c"
                                   TextWrapping="Wrap"
                                   LineHeight="22"
                                   TextAlignment="Justify"
                                   Margin="0,0,0,20"/>

                        <TextBlock Text="COMPLETE TEAM ROSTERS:"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   FontFamily="Times New Roman"
                                   Foreground="#2c2c2c"
                                   Margin="0,0,0,10"/>

                        <ItemsControl x:Name="RosterList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#f9f9f9" 
                                            BorderBrush="#cccccc" 
                                            BorderThickness="1"
                                            Margin="0,0,0,12"
                                            Padding="15">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Driver 1 Portrait -->
                                            <Border Grid.Column="0"
                                                    Width="60"
                                                    Height="75"
                                                    BorderBrush="#2c2c2c"
                                                    BorderThickness="1"
                                                    Background="White"
                                                    Margin="0,0,8,0"
                                                    VerticalAlignment="Top">
                                                <Image Source="{Binding Driver1Portrait}"
                                                       Stretch="Uniform"/>
                                            </Border>

                                            <!-- Driver 2 Portrait -->
                                            <Border Grid.Column="1"
                                                    Width="60"
                                                    Height="75"
                                                    BorderBrush="#2c2c2c"
                                                    BorderThickness="1"
                                                    Background="White"
                                                    Margin="0,0,12,0"
                                                    VerticalAlignment="Top">
                                                <Image Source="{Binding Driver2Portrait}"
                                                       Stretch="Uniform"/>
                                            </Border>

                                            <!-- Text Content -->
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="{Binding TeamName}"
                                                           FontSize="14"
                                                           FontWeight="Bold"
                                                           FontFamily="Times New Roman"
                                                           Foreground="#2c2c2c"
                                                           Margin="0,0,0,8"/>

                                                <TextBlock Text="{Binding DriversText}"
                                                           FontSize="13"
                                                           FontWeight="SemiBold"
                                                           FontFamily="Times New Roman"
                                                           Foreground="#1976d2"
                                                           Margin="0,0,0,8"/>

                                                <!-- Status line (unchanged/champion info) -->
                                                <TextBlock Text="{Binding StatusText}"
                                                           FontSize="11.5"
                                                           FontStyle="Italic"
                                                           FontFamily="Times New Roman"
                                                           Foreground="#c41e3a"
                                                           Margin="0,0,0,6"
                                                           TextWrapping="Wrap"
                                                           Visibility="{Binding StatusTextVisibility}"/>

                                                <!-- Description line -->
                                                <TextBlock Text="{Binding DescriptionText}"
                                                           FontSize="12"
                                                           FontFamily="Times New Roman"
                                                           Foreground="#555555"
                                                           TextWrapping="Wrap"
                                                           LineHeight="18"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock x:Name="ClosingText"
                                   FontSize="14"
                                   FontFamily="Times New Roman"
                                   Foreground="#2c2c2c"
                                   TextWrapping="Wrap"
                                   LineHeight="22"
                                   TextAlignment="Justify"
                                   Margin="0,20,0,0"/>
                    </StackPanel>
                </ScrollViewer>

                <Button x:Name="StartSeasonButton"
                        Grid.Row="4"
                        Content="START NEW SEASON!"
                        Style="{StaticResource ButtonStyle}"
                        HorizontalAlignment="Center"
                        Margin="0,20,0,0"
                        Click="StartSeasonButton_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
