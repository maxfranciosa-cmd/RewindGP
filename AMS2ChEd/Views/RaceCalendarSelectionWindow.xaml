<?xml version="1.0" encoding="utf-8"?>
<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        mc:Ignorable="d" 
        x:Class="AMS2ChEd.RaceCalendarSelectionWindow"
        Title="Calendar Selection" 
        Height="900" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#1a1a1a"
        ResizeMode="NoResize">

    <Window.Resources>
        <!-- Confirm Button Style -->
        <Style x:Key="ConfirmButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#dc143c" Offset="0"/>
                        <GradientStop Color="#b01030" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Black" BlurRadius="10" ShadowDepth="4" Opacity="0.3"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <ScaleTransform ScaleX="1.05" ScaleY="1.05"/>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="Black" BlurRadius="15" ShadowDepth="6" Opacity="0.4"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.5"/>
                    <Setter Property="Cursor" Value="Arrow"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Race Item Style -->
        <Style x:Key="RaceItemStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#222222"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Height" Value="60"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsEven}" Value="True">
                    <Setter Property="Background" Value="#0f0f0f"/>
                </DataTrigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2a2a2a"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Header Style -->
        <Style x:Key="HeaderStyle" TargetType="{x:Type Border}">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#dc143c" Offset="0"/>
                        <GradientStop Color="#b01030" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Height" Value="55"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#dc143c" BlurRadius="10" ShadowDepth="0" Opacity="0.4"/>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ModernCheckBoxStyle" TargetType="{x:Type CheckBox}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type CheckBox}">
                        <Grid Background="Transparent">
                            <Border x:Name="Border"
                                   Width="24"
                                   Height="24"
                                   BorderThickness="2"
                                   BorderBrush="#666666"
                                   Background="#1a1a1a"
                                   CornerRadius="3">
                                <Path x:Name="CheckMark"
                                     Data="M 0,5 L 4,9 L 10,0"
                                     Stroke="White"
                                     StrokeThickness="2.5"
                                     Visibility="Collapsed"
                                     Margin="3"/>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="Border" Property="Background" Value="#dc143c"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="#dc143c"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#dc143c"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header Section -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock x:Name="SeasonText" 
                       FontSize="42" 
                       FontWeight="Bold" 
                       Foreground="White"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,5">
                <TextBlock.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="6" ShadowDepth="3" Opacity="0.5"/>
                </TextBlock.Effect>
            </TextBlock>

            <TextBlock Text="CALENDAR SELECTION"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="#dc143c"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,10"/>

            <TextBlock Text="Select which races to remove from the calendar"
                       FontSize="11"
                       Foreground="#999999"
                       HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- Info Banner -->
        <Border Grid.Row="1" 
                Background="#2a1a1a"
                BorderBrush="#dc143c"
                BorderThickness="2"
                CornerRadius="4"
                Padding="20,15"
                Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock FontSize="14" Foreground="White" VerticalAlignment="Center">
                    <Run Text="Races Selected:" FontWeight="SemiBold"/>
                    <Run x:Name="SelectedCountText" Text="0" Foreground="#dc143c" FontWeight="Bold"/>
                    <Run Text="/" FontWeight="Normal"/>
                    <Run x:Name="TotalCountText" Text="0" FontWeight="Normal"/>
                </TextBlock>
                <TextBlock x:Name="WarningText" 
                           Text="⚠ At least one race must remain in the calendar"
                           FontSize="13"
                           Foreground="#ff6b6b"
                           FontWeight="SemiBold"
                           Margin="30,0,0,0"
                           VerticalAlignment="Center"
                           Visibility="Collapsed"/>
            </StackPanel>
        </Border>

        <!-- Race List -->
        <Border Grid.Row="2" 
                Background="#0a0a0a" 
                BorderBrush="#dc143c" 
                BorderThickness="2"
                CornerRadius="0">
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="10" ShadowDepth="4" Opacity="0.5"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- List Header -->
                <Border Grid.Row="0" 
                        Style="{StaticResource HeaderStyle}">
                    <Grid Margin="20,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="75"/>
                            <ColumnDefinition Width="75"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" 
                                   Text="ROUND" 
                                   FontSize="13" 
                                   FontWeight="Bold" 
                                   Foreground="White"
                                   VerticalAlignment="Center"/>

                        <TextBlock Grid.Column="1" 
                                   Text="GRAND PRIX" 
                                   FontSize="13" 
                                   FontWeight="Bold" 
                                   Foreground="White"
                                   VerticalAlignment="Center"/>

                        <TextBlock Grid.Column="2" 
                                   Text="CIRCUIT" 
                                   FontSize="13" 
                                   FontWeight="Bold" 
                                   Foreground="White"
                                   VerticalAlignment="Center"/>

                        <TextBlock Grid.Column="3" 
                                   Text="DATE" 
                                   FontSize="13" 
                                   FontWeight="Bold" 
                                   Foreground="White"
                                   VerticalAlignment="Center"/>

                        <TextBlock Grid.Column="4" 
                                   Text="INCLUDE" 
                                   FontSize="13" 
                                   FontWeight="Bold" 
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- Race Items -->
                <ScrollViewer Grid.Row="1" 
                              VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="RaceItems">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource RaceItemStyle}">
                                    <Grid Margin="20,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="100"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Round Number -->
                                        <TextBlock Grid.Column="0" 
                                                   Text="{Binding RoundNumber}"
                                                   FontSize="16"
                                                   FontWeight="Bold"
                                                   Foreground="#999999"
                                                   VerticalAlignment="Center"/>

                                        <!-- Race Name -->
                                        <TextBlock Grid.Column="1" 
                                                   Text="{Binding RaceName}"
                                                   FontSize="15"
                                                   Foreground="White"
                                                   VerticalAlignment="Center"/>

                                        <!-- Circuit Name -->
                                        <TextBlock Grid.Column="2" 
                                                   Text="{Binding CircuitName}"
                                                   FontSize="14"
                                                   Foreground="#cccccc"
                                                   VerticalAlignment="Center"/>

                                        <!-- Race Date -->
                                        <TextBlock Grid.Column="3" 
                                                   Text="{Binding FormattedDate}"
                                                   FontSize="13"
                                                   Foreground="#999999"
                                                   VerticalAlignment="Center"/>

                                        <!-- Checkbox -->
                                        <CheckBox Grid.Column="4"
                                                  IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Style="{DynamicResource ModernCheckBoxStyle}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Confirm Button -->
        <Button Grid.Row="3"
                x:Name="ConfirmButton"
                Content="CONFIRM CALENDAR"
                Style="{StaticResource ConfirmButtonStyle}"
                Margin="0,20,0,0"
                Click="ConfirmButton_Click"/>
    </Grid>
</Window>
