<Window x:Class="AMS2ChEd.Views.PreQualiResultsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:AMS2ChEd.Views"
        Title="Pre-Qualifying Results"
        Height="1200" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#f8f8f0"
        ResizeMode="CanResize">

    <Window.Resources>
        <local:BoolToFontWeightConverter x:Key="BoolToFontWeightConverter"/>
        <local:UpperCaseConverter x:Key="UpperCaseConverter"/>

        <Style x:Key="HeaderTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Courier New"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="Black"/>
        </Style>

        <Style x:Key="EntryTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Courier New"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="Black"/>
        </Style>
    </Window.Resources>

    <Border Background="White"
            BorderBrush="Black"
            BorderThickness="4"
            Margin="40">
        <Grid Margin="40">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Header -->
                <RowDefinition Height="Auto"/>
                <!-- Column headers -->
                <RowDefinition Height="*"/>
                <!-- Results list -->
                <RowDefinition Height="Auto"/>
                <!-- Footer -->
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <Rectangle Height="4" Fill="Black" Margin="0,0,0,5"/>
                <Rectangle Height="2" Fill="Black" Margin="0,0,0,10"/>

                <!-- Gold pre-qualifying banner -->
                <Border Background="Black" Margin="0,0,0,8">
                    <TextBlock Text="PRE-QUALIFYING SESSION"
                               FontFamily="Arial Black"
                               FontSize="13"
                               FontWeight="Black"
                               Foreground="#FFD700"
                               HorizontalAlignment="Center"
                               Padding="0,6"/>
                </Border>

                <TextBlock Text="OFFICIAL RESULTS"
                           FontFamily="Arial Black"
                           FontSize="20"
                           FontWeight="Black"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,5"/>

                <TextBlock x:Name="GrandPrixText"
                           FontFamily="Arial Black"
                           FontSize="16"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,5"/>

                <TextBlock x:Name="SessionSummaryText"
                           FontFamily="Arial"
                           FontSize="11"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,10"/>

                <Rectangle Height="2" Fill="Black" Margin="0,0,0,5"/>
                <Rectangle Height="4" Fill="Black"/>
            </StackPanel>

            <!-- Column Headers -->
            <Grid Grid.Row="1" Margin="0,10,0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="50"/>
                    <!-- P -->
                    <ColumnDefinition Width="50"/>
                    <!-- No. -->
                    <ColumnDefinition Width="220"/>
                    <!-- Driver -->
                    <ColumnDefinition Width="*"/>
                    <!-- Team -->
                    <ColumnDefinition Width="110"/>
                    <!-- Best Lap -->
                    <ColumnDefinition Width="120"/>
                    <!-- Status -->
                </Grid.ColumnDefinitions>

                <Rectangle Grid.Column="0" Grid.ColumnSpan="6"
                           Height="1" Fill="Black"
                           VerticalAlignment="Bottom"/>

                <TextBlock Grid.Column="0" Text="P"   Style="{StaticResource HeaderTextStyle}" Margin="5,0"/>
                <TextBlock Grid.Column="1" Text="No." Style="{StaticResource HeaderTextStyle}" Margin="5,0"/>
                <TextBlock Grid.Column="2" Text="DRIVER" Style="{StaticResource HeaderTextStyle}" Margin="5,0"/>
                <TextBlock Grid.Column="3" Text="TEAM"   Style="{StaticResource HeaderTextStyle}" Margin="5,0"/>
                <TextBlock Grid.Column="4" Text="BEST LAP" Style="{StaticResource HeaderTextStyle}" Margin="5,0"/>
                <TextBlock Grid.Column="5" Text="STATUS" Style="{StaticResource HeaderTextStyle}" Margin="5,0"/>
            </Grid>

            <!-- Results List -->
            <ScrollViewer Grid.Row="2"
                          VerticalScrollBarVisibility="Auto"
                          Margin="0,5,0,10">
                <ItemsControl x:Name="ResultsItems">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <!-- Separator row injected via IsDivider flag -->
                            <StackPanel>

                                <!-- DNPQ Divider — only visible on the first eliminated row -->
                                <Border Visibility="{Binding DividerVisibility}"
                                        Background="Black"
                                        Padding="5,4"
                                        Margin="0,4,0,0">
                                    <TextBlock Text="DID NOT PRE-QUALIFY"
                                               FontFamily="Arial Black"
                                               FontSize="11"
                                               FontWeight="Black"
                                               Foreground="White"
                                               HorizontalAlignment="Center"/>
                                </Border>

                                <!-- Result row -->
                                <Border BorderBrush="Black"
                                        BorderThickness="0,0,0,1"
                                        Background="{Binding RowBackground}"
                                        Padding="0,7">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="50"/>
                                            <ColumnDefinition Width="50"/>
                                            <ColumnDefinition Width="220"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="120"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Position -->
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Position}"
                                                   Style="{StaticResource EntryTextStyle}"
                                                   Foreground="{Binding RowForeground}"
                                                   FontWeight="Bold"
                                                   Margin="10,0,5,0"/>

                                        <!-- Number -->
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Number}"
                                                   Style="{StaticResource EntryTextStyle}"
                                                   Foreground="{Binding RowForeground}"
                                                   Margin="5,0"/>

                                        <!-- Driver Name -->
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding DriverName, Converter={StaticResource UpperCaseConverter}}"
                                                   Style="{StaticResource EntryTextStyle}"
                                                   Foreground="{Binding RowForeground}"
                                                   FontWeight="{Binding IsPlayer, Converter={StaticResource BoolToFontWeightConverter}}"
                                                   Margin="5,0"/>

                                        <!-- Team -->
                                        <TextBlock Grid.Column="3"
                                                   Text="{Binding TeamName, Converter={StaticResource UpperCaseConverter}}"
                                                   Style="{StaticResource EntryTextStyle}"
                                                   Foreground="{Binding RowForeground}"
                                                   Margin="5,0"/>

                                        <!-- Best Lap -->
                                        <TextBlock Grid.Column="4"
                                                   Text="{Binding BestLapTime}"
                                                   Style="{StaticResource EntryTextStyle}"
                                                   Foreground="{Binding RowForeground}"
                                                   Margin="5,0"/>

                                        <!-- Status badge -->
                                        <Border Grid.Column="5"
                                                Background="{Binding StatusBackground}"
                                                Padding="6,2"
                                                HorizontalAlignment="Left"
                                                Margin="5,0"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{Binding StatusText}"
                                                       FontFamily="Arial Black"
                                                       FontSize="10"
                                                       FontWeight="Black"
                                                       Foreground="{Binding StatusForeground}"/>
                                        </Border>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Footer -->
            <StackPanel Grid.Row="3">
                <Rectangle Height="2" Fill="Black" Margin="0,0,0,10"/>

                <TextBlock x:Name="FooterText"
                           FontFamily="Arial"
                           FontSize="10"
                           FontStyle="Italic"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,10"/>

                <Button x:Name="ContinueButton"
                        Content="CONTINUE TO ENTRY LIST"
                        Width="260"
                        Height="40"
                        FontFamily="Arial"
                        FontWeight="Bold"
                        FontSize="13"
                        Background="Black"
                        Foreground="White"
                        BorderThickness="0"
                        HorizontalAlignment="Center"
                        Cursor="Hand"
                        Click="ContinueButton_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Black"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderThickness="0"
                                                Padding="10,5">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#333333"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
