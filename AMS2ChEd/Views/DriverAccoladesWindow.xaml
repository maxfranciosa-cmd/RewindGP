<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="AMS2ChEd.Views.DriverAccoladesWindow"
        Title="Driver Accolades"
        Height="520" Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#1a1a1a">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header: photo + name -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="110"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Driver photo -->
            <Grid Grid.Column="0">
                <Border Width="80" Height="114"
                        CornerRadius="4"
                        Background="#2a2a2a"
                        BorderBrush="#dc143c"
                        BorderThickness="2">
                    <Grid>
                        <TextBlock x:Name="PhotoPlaceholder"
                                   Text="?"
                                   FontSize="36"
                                   Foreground="#555555"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                        <Image x:Name="DriverPhoto"
                               Stretch="UniformToFill"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- Driver name + label -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="20,0,0,0">
                <TextBlock x:Name="DriverNameText"
                           FontSize="26"
                           FontWeight="Bold"
                           Foreground="White"
                           TextWrapping="Wrap"
                           Margin="0,6,0,0"/>
                <TextBlock x:Name="TeamNameText"
                           FontSize="18"
                           Foreground="#666666"
                           TextWrapping="Wrap"
                           Margin="0,6,0,0"/>
            </StackPanel>
        </Grid>

        <!-- Red divider -->
        <Border Grid.Row="1"
                Height="2"
                Background="#dc143c"
                Margin="0,9,0,9"
                VerticalAlignment="Center"/>

        <!-- Stat blocks -->
        <UniformGrid Grid.Row="2" Columns="3" Rows="1">

            <!-- Wins -->
            <Border Background="#0f0f0f"
                    BorderBrush="#2a2a2a"
                    BorderThickness="1"
                    CornerRadius="4"
                    Margin="0,0,8,0"
                    Padding="16,14">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock x:Name="WinsText"
                               FontSize="36"
                               FontWeight="Bold"
                               Foreground="White"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="WINS"
                               FontSize="11"
                               FontWeight="Bold"
                               Foreground="#666666"
                               HorizontalAlignment="Center"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Podiums -->
            <Border Background="#0f0f0f"
                    BorderBrush="#2a2a2a"
                    BorderThickness="1"
                    CornerRadius="4"
                    Margin="0,0,8,0"
                    Padding="16,14">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock x:Name="PodiumsText"
                               FontSize="36"
                               FontWeight="Bold"
                               Foreground="White"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="PODIUMS"
                               FontSize="11"
                               FontWeight="Bold"
                               Foreground="#666666"
                               HorizontalAlignment="Center"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Poles -->
            <Border Background="#0f0f0f"
                    BorderBrush="#2a2a2a"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="16,14">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock x:Name="PolesText"
                               FontSize="36"
                               FontWeight="Bold"
                               Foreground="White"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="POLES"
                               FontSize="11"
                               FontWeight="Bold"
                               Foreground="#666666"
                               HorizontalAlignment="Center"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- Championships -->
        <Border Grid.Row="4"
                Background="#0f0f0f"
                BorderBrush="#2a2a2a"
                BorderThickness="1"
                CornerRadius="4"
                Padding="16,14">
            <StackPanel>
                <TextBlock Text="CHAMPIONSHIPS"
                           FontSize="11"
                           FontWeight="Bold"
                           Foreground="#666666"
                           Margin="0,0,0,10"/>
                <WrapPanel x:Name="ChampionshipsPanel">
                    <!-- championship year badges populated in code-behind -->
                </WrapPanel>
                <TextBlock x:Name="NoChampionshipsText"
                           Text="—"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="#333333"
                           Visibility="Collapsed"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
