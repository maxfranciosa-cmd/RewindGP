<Window x:Class="AMS2ChEd.ConstructorStandingsGridWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Constructor Standings - Season Results" 
        Height="700" Width="1200"
        WindowStartupLocation="CenterOwner"
        Background="#f8f8f0"
        ResizeMode="CanResize">

    <Window.Resources>
        <Style x:Key="HeaderTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Courier New"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>

        <Style x:Key="TeamNameTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Arial Black"/>
            <Setter Property="FontWeight" Value="Black"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Padding" Value="8,5"/>
        </Style>

        <Style x:Key="DriverNameTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Courier New"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Padding" Value="20,0,0,0"/>
        </Style>
    </Window.Resources>

    <Border Background="White" 
            BorderBrush="Black" 
            BorderThickness="4"
            Margin="40">
        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Official Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <!-- Top border -->
                <Rectangle Height="4" Fill="Black" Margin="0,0,0,5"/>
                <Rectangle Height="2" Fill="Black" Margin="0,0,0,10"/>

                <TextBlock Text="CONSTRUCTOR STANDINGS"
                           FontFamily="Arial Black"
                           FontSize="20"
                           FontWeight="Black"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,5"/>

                <TextBlock x:Name="SeasonYearText"
                           FontFamily="Arial"
                           FontSize="12"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,10"/>

                <!-- Bottom border -->
                <Rectangle Height="2" Fill="Black" Margin="0,0,0,5"/>
                <Rectangle Height="4" Fill="Black"/>
            </StackPanel>

            <!-- Scrollable content -->
            <ScrollViewer Grid.Row="1" 
                          HorizontalScrollBarVisibility="Auto" 
                          VerticalScrollBarVisibility="Auto"
                          Margin="0,10,0,10">
                <Border BorderBrush="Black" BorderThickness="2" Background="White">
                    <StackPanel x:Name="TeamsStackPanel" Margin="0">
                        <!-- Teams will be populated dynamically -->
                    </StackPanel>
                </Border>
            </ScrollViewer>

            <!-- Footer -->
            <StackPanel Grid.Row="2">
                <Rectangle Height="2" Fill="Black" Margin="0,0,0,10"/>
                <TextBlock Text="Results compiled from race data"
                           FontFamily="Arial"
                           FontSize="10"
                           FontStyle="Italic"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
