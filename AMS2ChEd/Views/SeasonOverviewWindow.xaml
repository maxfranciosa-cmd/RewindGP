<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        mc:Ignorable="d" 
        x:Class="AMS2ChEd.SeasonOverviewWindow"
        Title="Season Overview" 
        Height="900" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#1a1a1a">

    <Window.Resources>
        <!-- Featured Race Card Button Style -->
        <Style x:Key="NextButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="White" Offset="0"/>
                        <GradientStop Color="#f0f0f0" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="#c41e3a"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Black" BlurRadius="10" ShadowDepth="4" Opacity="0.3"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <ScaleTransform ScaleX="1.05" ScaleY="1.05"/>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="Black" BlurRadius="15" ShadowDepth="6" Opacity="0.4"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Standings Header Style with Gradient -->
        <Style x:Key="StandingsHeaderStyle" TargetType="{x:Type Border}">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#dc143c" Offset="0"/>
                        <GradientStop Color="#b01030" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Height" Value="55"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#dc143c" BlurRadius="10" ShadowDepth="0" Opacity="0.4"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Standing Item Style with Alternating Rows -->
        <Style x:Key="StandingItemStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#222222"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Height" Value="40"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsEven}" Value="True">
                    <Setter Property="Background" Value="#0f0f0f"/>
                </DataTrigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1a1a1a"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Player Highlight Style -->
        <Style x:Key="PlayerStandingStyle" TargetType="{x:Type Border}" BasedOn="{StaticResource StandingItemStyle}">
            <Setter Property="Background" Value="#2a1a1a"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3a2a2a"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Race Number Badge Style -->
        <Style x:Key="RaceNumberStyle" TargetType="{x:Type Border}">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Background" Value="#dc143c"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
        </Style>

        <!-- Team Color Strip Style -->
        <Style x:Key="TeamColorStyle" TargetType="{x:Type Border}">
            <Setter Property="Width" Value="5"/>
            <Setter Property="CornerRadius" Value="2"/>
            <Setter Property="Margin" Value="0,0,15,0"/>
        </Style>

        <!-- Player Info Button Style -->
        <Style x:Key="PlayerInfoButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="#2a2a2a"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3a3a3a"/>
                    <Setter Property="BorderBrush" Value="#c41e3a"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header Section with Player Info -->
        <Grid Grid.Row="0" Margin="0,0,0,30">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Season Title and Subtitle -->
            <Border Grid.Column="0" 
        Background="#0a0a0a" 
        BorderBrush="#dc143c" 
        BorderThickness="2"
        CornerRadius="0"
        Padding="20">
                <Border.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="10" ShadowDepth="4" Opacity="0.5"/>
                </Border.Effect>
                <Grid>
                    <!-- Season text - larger and more prominent -->
                    <TextBlock x:Name="SeasonText"
                   Text="Season: {Year}"
                   FontSize="42" 
                   FontWeight="Bold" 
                   Foreground="White"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>

                    <!-- Small icon button in top-right corner -->
                    <Button x:Name="HistoricalStandingsButton"
                Click="HistoricalStandingsButton_Click"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Width="24"
                Height="24"
                Background="Transparent"
                BorderBrush="#444444"
                BorderThickness="1"
                Cursor="Hand"
                ToolTip="View historical championship standings from previous seasons">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="3">
                                    <!-- Clock/History icon -->
                                    <Viewbox Width="12" Height="12">
                                        <Canvas Width="16" Height="16">
                                            <!-- Clock circle -->
                                            <Ellipse Width="14" Height="14" Canvas.Left="1" Canvas.Top="1" 
                                         Stroke="#888888" StrokeThickness="1.5" Fill="Transparent"/>
                                            <!-- Clock hand pointing to 10 o'clock (past) -->
                                            <Line X1="8" Y1="8" X2="8" Y2="4" 
                                      Stroke="#888888" StrokeThickness="1.5" />
                                            <Line X1="8" Y1="8" X2="5" Y2="5.5" 
                                      Stroke="#888888" StrokeThickness="1.5"/>
                                        </Canvas>
                                    </Viewbox>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#1a1a1a"/>
                                        <Setter Property="BorderBrush" Value="#666666"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- Player Info Box -->
            <Border Grid.Column="1"
                    Background="#0a0a0a"
                    BorderBrush="#c41e3a"
                    BorderThickness="2"
                    CornerRadius="0"
                    Padding="15"
                    MinWidth="300"
                    VerticalAlignment="Top">
                <Border.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="10" ShadowDepth="4" Opacity="0.5"/>
                </Border.Effect>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Player Photo -->
                    <Border Grid.Column="0"
                            Width="80"
                            Height="114"
                            Background="#1a1a1a"
                            BorderBrush="#555555"
                            BorderThickness="1"
                            Margin="0,0,15,0"
                            VerticalAlignment="Top">
                        <Grid>
                            <!-- Photo Image -->
                            <Image x:Name="PlayerPhotoImage"
                                   Stretch="UniformToFill"
                                   HorizontalAlignment="Center"/>

                            <!-- Placeholder if no photo -->
                            <TextBlock x:Name="PlayerPhotoPlaceholder"
                                       Text="?"
                                       FontSize="36"
                                       FontWeight="Bold"
                                       Foreground="#333333"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Visibility="Collapsed"/>
                        </Grid>
                    </Border>

                    <!-- Player Info -->
                    <StackPanel Grid.Column="1">
                        <!-- Header -->
                        <TextBlock Text="PLAYER"
                                   FontSize="11"
                                   FontWeight="Bold"
                                   Foreground="#c41e3a"
                                   Margin="0,0,0,12"/>

                        <!-- Player Name -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Name:"
                                       FontSize="12"
                                       Foreground="#666666"
                                       Margin="0,0,10,0"/>
                            <TextBlock Grid.Column="1"
                                       x:Name="PlayerNameText"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="White"
                                       TextWrapping="Wrap"/>
                        </Grid>

                        <!-- Player Team -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Team:"
                                       FontSize="12"
                                       Foreground="#666666"
                                       Margin="0,0,10,0"/>
                            <TextBlock Grid.Column="1"
                                       x:Name="PlayerTeamText"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="White"
                                       TextWrapping="Wrap"/>
                        </Grid>

                        <!-- Player Reputation -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Reputation:"
                                       FontSize="12"
                                       Foreground="#666666"
                                       Margin="0,0,10,0"/>
                            <TextBlock Grid.Column="1"
                                       x:Name="PlayerReputationText"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="#c41e3a"
                                       TextWrapping="Wrap"/>
                        </Grid>

                        <!-- Edit Button -->
                        <Button x:Name="EditPlayerButton"
                                Click="EditPlayerButton_Click"
                                Style="{StaticResource PlayerInfoButtonStyle}"
                                Content="Edit Details"
                                FontSize="11"
                                FontWeight="SemiBold"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Next Race Section -->
        <Border Grid.Row="1" 
                Background="#0a0a0a" 
                BorderBrush="#c41e3a" 
                BorderThickness="2"
                CornerRadius="0"
                Margin="0,0,0,30"
                Height="180">
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="10" ShadowDepth="4" Opacity="0.5"/>
            </Border.Effect>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Race Info -->
                <StackPanel Grid.Column="0" 
                            VerticalAlignment="Center"
                            Margin="40,0">
                    <TextBlock Text="NEXT GRAND PRIX"
                               FontSize="11"
                               Foreground="#999999"
                               Margin="0,0,0,8"/>

                    <TextBlock x:Name="NextGPText"
                               FontSize="36"
                               FontWeight="Bold"
                               Foreground="White"
                               Margin="0,0,0,8">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="#c41e3a" BlurRadius="8" ShadowDepth="0" Opacity="0.3"/>
                        </TextBlock.Effect>
                    </TextBlock>

                    <TextBlock x:Name="RaceInfoText"
                               FontSize="13"
                               Foreground="#666666"/>
                </StackPanel>

                <!-- Action Button -->
                <Button x:Name="NextButton" 
                        Grid.Column="1"
                        Click="NextButton_Click"
                        Style="{StaticResource NextButtonStyle}"
                        Width="180"
                        Margin="0,0,40,0"
                        VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="PROCEED"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- Standings Section -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Driver Standings -->
            <Border Grid.Column="0" 
                    Background="#0a0a0a" 
                    BorderBrush="#dc143c" 
                    BorderThickness="2"
                    CornerRadius="0">
                <Border.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="10" ShadowDepth="4" Opacity="0.5"/>
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Border Grid.Row="0" 
                            Style="{StaticResource StandingsHeaderStyle}">
                        <Grid>
                            <TextBlock Text="DRIVER STANDINGS" 
                                       FontSize="16" 
                                       FontWeight="Bold" 
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>

                            <!-- Grid View Button -->
                            <Button x:Name="DriverGridButton"
                                    Click="DriverGridButton_Click"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Margin="0,0,10,0"
                                    Width="28"
                                    Height="28"
                                    Background="#2a2a2a"
                                    BorderBrush="#555555"
                                    BorderThickness="1"
                                    Cursor="Hand"
                                    ToolTip="View race-by-race grid">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="3">
                                            <Grid>
                                                <!-- Grid icon -->
                                                <Viewbox Width="16" Height="16">
                                                    <Canvas Width="16" Height="16">
                                                        <!-- Horizontal lines -->
                                                        <Rectangle Width="14" Height="1.5" Canvas.Left="1" Canvas.Top="3" Fill="White"/>
                                                        <Rectangle Width="14" Height="1.5" Canvas.Left="1" Canvas.Top="7.25" Fill="White"/>
                                                        <Rectangle Width="14" Height="1.5" Canvas.Left="1" Canvas.Top="11.5" Fill="White"/>
                                                        <!-- Vertical lines -->
                                                        <Rectangle Width="1.5" Height="14" Canvas.Left="5" Canvas.Top="1" Fill="White"/>
                                                        <Rectangle Width="1.5" Height="14" Canvas.Left="9.5" Canvas.Top="1" Fill="White"/>
                                                    </Canvas>
                                                </Viewbox>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#3a3a3a"/>
                                                <Setter Property="BorderBrush" Value="#c41e3a"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Standings List -->
                    <ScrollViewer Grid.Row="1" 
                                  VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="DriverStandingsItems">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border MouseLeftButtonDown="DriverRow_MouseDoubleClick"
                                            Cursor="Hand">
                                        <Border.Style>
                                            <Style TargetType="{x:Type Border}" BasedOn="{StaticResource StandingItemStyle}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsPlayer}" Value="True">
                                                        <Setter Property="Background" Value="#2a1a1a"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>

                                        <Grid Margin="15,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="35"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="70"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Position -->
                                            <TextBlock Grid.Column="0" 
                                                      Text="{Binding Position, StringFormat=\{0\}.}"
                                                      FontSize="14"
                                                      FontWeight="Bold"
                                                      Foreground="#999999"
                                                      VerticalAlignment="Center"/>

                                            <!-- Race Number Badge -->
                                            <Border Grid.Column="1"
                                                    Style="{StaticResource RaceNumberStyle}">
                                                <TextBlock Text="{Binding RaceNumber}"
                                                          FontSize="13"
                                                          FontWeight="Bold"
                                                          Foreground="White"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                            </Border>

                                            <!-- Driver Name -->
                                            <TextBlock Grid.Column="2" 
                                                      Text="{Binding DriverName}"
                                                      FontSize="14"
                                                      Foreground="White"
                                                      VerticalAlignment="Center"/>

                                            <!-- Points -->
                                            <TextBlock Grid.Column="3" 
                                                      Text="{Binding Points, StringFormat=\{0\}pt}"
                                                      FontSize="15"
                                                      FontWeight="SemiBold"
                                                      Foreground="#666666"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Right"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Constructor Standings -->
            <Border Grid.Column="2" 
                    Background="#0a0a0a" 
                    BorderBrush="#dc143c" 
                    BorderThickness="2"
                    CornerRadius="0">
                <Border.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="10" ShadowDepth="4" Opacity="0.5"/>
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <!-- Header -->
                    <Border Grid.Row="0" 
                            Style="{StaticResource StandingsHeaderStyle}">
                        <Grid>
                            <TextBlock Text="CONSTRUCTOR STANDINGS" 
                                       FontSize="16" 
                                       FontWeight="Bold" 
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>

                            <!-- Grid View Button -->
                            <Button x:Name="ConstructorGridButton"
                                    Click="ConstructorGridButton_Click"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Margin="0,0,10,0"
                                    Width="28"
                                    Height="28"
                                    Background="#2a2a2a"
                                    BorderBrush="#555555"
                                    BorderThickness="1"
                                    Cursor="Hand"
                                    ToolTip="View race-by-race grid">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="3">
                                            <Grid>
                                                <!-- Grid icon -->
                                                <Viewbox Width="16" Height="16">
                                                    <Canvas Width="16" Height="16">
                                                        <!-- Horizontal lines -->
                                                        <Rectangle Width="14" Height="1.5" Canvas.Left="1" Canvas.Top="3" Fill="White"/>
                                                        <Rectangle Width="14" Height="1.5" Canvas.Left="1" Canvas.Top="7.25" Fill="White"/>
                                                        <Rectangle Width="14" Height="1.5" Canvas.Left="1" Canvas.Top="11.5" Fill="White"/>
                                                        <!-- Vertical lines -->
                                                        <Rectangle Width="1.5" Height="14" Canvas.Left="5" Canvas.Top="1" Fill="White"/>
                                                        <Rectangle Width="1.5" Height="14" Canvas.Left="9.5" Canvas.Top="1" Fill="White"/>
                                                    </Canvas>
                                                </Viewbox>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#3a3a3a"/>
                                                <Setter Property="BorderBrush" Value="#c41e3a"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Standings List -->
                    <ScrollViewer Grid.Row="1" 
                                  VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="ConstructorStandingsItems">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border MouseLeftButtonDown="ConstructorRow_MouseDoubleClick"
                                            Cursor="Hand">
                                        <Border.Style>
                                            <Style TargetType="{x:Type Border}" BasedOn="{StaticResource StandingItemStyle}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsPlayerTeam}" Value="True">
                                                        <Setter Property="Background" Value="#2a1a1a"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>

                                        <Grid Margin="15,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="35"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="70"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Position -->
                                            <TextBlock Grid.Column="0" 
                                                      Text="{Binding Position, StringFormat=\{0\}.}"
                                                      FontSize="14"
                                                      FontWeight="Bold"
                                                      Foreground="#999999"
                                                      VerticalAlignment="Center"/>

                                            <!-- Team Color Strip -->
                                            <Border Grid.Column="1"
                                                    Style="{StaticResource TeamColorStyle}"
                                                    Background="{Binding TeamColor}"
                                                    Height="28"/>

                                            <!-- Team Name -->
                                            <TextBlock Grid.Column="2" 
                                                      Text="{Binding TeamName}"
                                                      FontSize="14"
                                                      Foreground="White"
                                                      VerticalAlignment="Center"/>

                                            <!-- Points -->
                                            <TextBlock Grid.Column="3" 
                                                      Text="{Binding Points, StringFormat=\{0\}pt}"
                                                      FontSize="15"
                                                      FontWeight="SemiBold"
                                                      Foreground="#666666"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Right"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
