<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="AMS2ChEd.GenerateAbsenceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pay Driver - Wild Card" 
        Height="700" Width="650"
        WindowStartupLocation="CenterScreen"
        Background="#1a1a1a"
        ResizeMode="NoResize">

    <Window.Resources>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#c41e3a"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="Padding" Value="25,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#d32f2f"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#cccccc"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="Padding" Value="25,0"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#888888"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,25">
            <TextBlock x:Name="TitleText"
                       Text="PAY DRIVER - WILD CARD"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="#c41e3a"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,10"/>
            <Rectangle Height="2" Fill="#c41e3a" Width="200" HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- Content -->
        <Border Grid.Row="1" 
                Background="#252525"
                BorderBrush="#444444"
                BorderThickness="1"
                CornerRadius="5"
                Padding="30">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock TextWrapping="Wrap"
                               FontSize="15"
                               Foreground="#e0e0e0"
                               LineHeight="26"
                               TextAlignment="Left">
                        <Run x:Name="IntroText1" Text="You are a pay driver wild card. This means that you can't secure a full season seat with a team yet, and you need to step in whenever one of the official drivers is absent."/>
                        <LineBreak/><LineBreak/>
                        <Run x:Name="IntroText2" Text="You need to seize every single opportunity you get in order to prove your worth and secure a full-season seat for next season."/>
                        <LineBreak/><LineBreak/>
                        <Run x:Name="IntroText3" Text="However, drivers might go a full season without any absences, so your opportunities may be limited or non-existent."/>
                        <LineBreak/><LineBreak/>
                        <Run x:Name="QuestionText" FontWeight="Bold" Foreground="#c41e3a" Text="Would you like to create a fictional absence for a random low/midlevel team driver in the next race?"/>
                        <LineBreak/><LineBreak/>
                        <Run FontStyle="Italic" Foreground="#999999" Text="This will guarantee you at least one race to prove yourself this season."/>
                    </TextBlock>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" 
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,30,0,0">
            <Button x:Name="YesButton"
                    Content="YES, CREATE ABSENCE"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Click="YesButton_Click"
                    Margin="0,0,15,0"/>
            <Button x:Name="NoButton"
                    Content="NO"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Click="NoButton_Click"/>
            <Button x:Name="BackButton"
                    Content="CHOOSE OTHER REPUTATION"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Margin="15,0,0,0" Click="BackButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
