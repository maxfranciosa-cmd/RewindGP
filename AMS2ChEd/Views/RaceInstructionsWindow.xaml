<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="AMS2ChEd.RaceInstructionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pay Driver - Wild Card" 
        Height="700" Width="650"
        WindowStartupLocation="CenterScreen"
        Background="#1a1a1a"
        ResizeMode="NoResize">

    <Window.Resources>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#c41e3a"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="Padding" Value="25,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#d32f2f"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#cccccc"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="Padding" Value="25,0"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#888888"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,25">
            <TextBlock x:Name="TitleText"
                       Text="READY TO GO!"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="#c41e3a"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,10"/>
            <Rectangle Height="2" Fill="#c41e3a" Width="200" HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- Content -->
        <Border Grid.Row="1" 
                Background="#252525"
                BorderBrush="#444444"
                BorderThickness="1"
                CornerRadius="5"
                Padding="30">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock TextWrapping="Wrap"
                               FontSize="15"
                               Foreground="#e0e0e0"
                               LineHeight="26"
                               TextAlignment="Left">
                        <Run x:Name="IntroText1" Text=""/>
                        <LineBreak/><LineBreak/>
                        <Run x:Name="IntroText2" Text=""/>
                        <LineBreak/><LineBreak/>
                        <Run x:Name="IntroText3" Text=""/>
                        <LineBreak/><LineBreak/>
                        <Run x:Name="IntroText4" Text=""/>
                        <LineBreak/><LineBreak/>
                        <Run FontStyle="Italic" Foreground="#999999" Text="the app will automatically save the qualy results and the race results."/>
                    </TextBlock>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" 
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,30,0,0">
            <Button x:Name="OkButton"
                    Content="OK, I'M READY!"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Click="OkButton_Click"
                    Margin="0,0,15,0"/>
        </StackPanel>
    </Grid>
</Window>
