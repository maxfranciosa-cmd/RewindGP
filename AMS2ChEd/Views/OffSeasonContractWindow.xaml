<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="AMS2ChEd.Views.OffSeasonContractWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Contract Decision" 
        Height="800" Width="800"
        WindowStartupLocation="CenterScreen"
        Background="#f5f5dc"
        ResizeMode="NoResize">

    <Window.Resources>
        <Style x:Key="AcceptButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#2e7d32"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="Width" Value="140"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#388e3c"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="RejectButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#c41e3a"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="Width" Value="140"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#d32f2f"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ContinueButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#2c2c2c"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="Width" Value="140"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3c3c3c"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Letter Content -->
        <Border Grid.Row="0" 
                Background="White" 
                BorderBrush="#8b7355" 
                BorderThickness="2"
                Margin="40,30,40,20"
                CornerRadius="3">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="3" Opacity="0.3"/>
            </Border.Effect>

            <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="50,40">
                <StackPanel>
                    <!-- Team Letterhead -->
                    <TextBlock x:Name="TeamNameHeader"
                               FontSize="24" 
                               FontWeight="Bold" 
                               Foreground="#2c2c2c"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,5"/>

                    <TextBlock Text="Formula Racing Team"
                               FontSize="12" 
                               Foreground="#666666"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,30"/>

                    <Rectangle Height="1" Fill="#cccccc" Margin="0,0,0,30"/>

                    <!-- Letter Body -->
                    <TextBlock x:Name="LetterContent"
                               FontSize="14"
                               Foreground="#2c2c2c"
                               TextWrapping="Wrap"
                               LineHeight="24"
                               FontFamily="Georgia"
                               TextAlignment="Left"/>

                    <!-- Signature -->
                    <TextBlock Text="Sincerely,"
                               FontSize="14"
                               Foreground="#2c2c2c"
                               FontFamily="Georgia"
                               Margin="0,40,0,10"/>

                    <TextBlock x:Name="SignatureName"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="#2c2c2c"
                               FontFamily="Segoe Script"
                               Margin="0,0,0,5"/>

                    <TextBlock x:Name="SignatureTitle"
                               FontSize="12"
                               Foreground="#666666"
                               FontFamily="Georgia"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="1" 
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,30"
                    x:Name="ButtonPanel">
            <Button x:Name="AcceptButton"
                    Content="ACCEPT" 
                    Style="{StaticResource AcceptButtonStyle}"
                    Click="AcceptButton_Click"
                    Margin="0,0,10,0"
                    Visibility="Collapsed"/>
            <Button x:Name="RejectButton"
                    Content="REJECT"
                    Style="{StaticResource RejectButtonStyle}"
                    Click="RejectButton_Click"
                    Visibility="Collapsed"/>
            <Button x:Name="ContinueButton"
                    Content="CONTINUE"
                    Style="{StaticResource ContinueButtonStyle}"
                    Click="ContinueButton_Click"
                    Visibility="Collapsed"/>
        </StackPanel>
    </Grid>
</Window>
