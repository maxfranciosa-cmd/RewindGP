<Window x:Class="AMS2ChEd.Dialogs.SeasonCatalogDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Season Packs"
        Width="560" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#1a1a1a"
        Foreground="White">

    <Window.Resources>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#c41e3a"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#d32f2f"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#555555"/>
                    <Setter Property="Foreground" Value="#888888"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#555555"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#666666"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="HeaderText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#cccccc"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <StackPanel Margin="24,24,24,24">

        <TextBlock Text="SEASON PACKS"
                   FontSize="20" FontWeight="Bold"
                   Foreground="#c41e3a" Margin="0,0,0,4"/>
        <TextBlock FontSize="13" Foreground="#cccccc" Margin="0,0,0,20"
                   TextWrapping="Wrap">
            Select season packs to download. Download pages will open in your browser — locate each file after downloading.
        </TextBlock>

        <!-- Grid header -->
        <Grid Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="30"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="130"/>
                <ColumnDefinition Width="80"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="1" Text="SEASON" Style="{StaticResource HeaderText}"/>
            <TextBlock Grid.Column="2" Text="STATUS" Style="{StaticResource HeaderText}"/>
            <TextBlock Grid.Column="3" Text="SIZE" Style="{StaticResource HeaderText}" HorizontalAlignment="Right"/>
        </Grid>

        <Rectangle Height="2" Fill="#c41e3a" Margin="0,0,0,0"/>

        <!-- Season rows -->
        <Border Background="#2a2a2a" Margin="0,0,0,16">
            <ItemsControl x:Name="SeasonsItemsControl">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="30"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>

                            <CheckBox Grid.Column="0"
                                      IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                      IsEnabled="{Binding CanSelect}"
                                      VerticalAlignment="Center"
                                      Margin="4,10,0,10"/>

                            <TextBlock Grid.Column="1"
                                       Text="{Binding DisplayName}"
                                       FontSize="14" Foreground="White"
                                       VerticalAlignment="Center"
                                       Margin="0,10,8,10"/>

                            <Border Grid.Column="2" VerticalAlignment="Center"
                                    Padding="8,3" Margin="0,8,8,8" HorizontalAlignment="Left">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#555555"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Availability}" Value="UpdateAvailable">
                                                <Setter Property="Background" Value="#c41e3a"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Availability}" Value="NotInstalled">
                                                <Setter Property="Background" Value="#2a2a2a"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Availability}" Value="UpToDate">
                                                <Setter Property="Background" Value="#2d6a2d"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding StatusLabel}"
                                           FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                            </Border>

                            <TextBlock Grid.Column="3"
                                       Text="{Binding FileSizeLabel}"
                                       FontSize="13" Foreground="#cccccc"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Right"
                                       Margin="0,10,4,10"/>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>

        <!-- Status label (shown during install) -->
        <StackPanel x:Name="StatusPanel" Visibility="Collapsed" Margin="0,0,0,16">
            <TextBlock x:Name="StatusLabel"
                       FontSize="13" FontWeight="SemiBold"
                       Foreground="#cccccc"/>
        </StackPanel>

        <!-- Buttons -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="15"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button x:Name="CloseButton"
                    Grid.Column="0"
                    Content="CLOSE"
                    Style="{StaticResource SecondaryButton}"
                    Click="OnCloseClicked"/>

            <Button x:Name="DownloadButton"
                    Grid.Column="2"
                    Content="DOWNLOAD SELECTED"
                    Style="{StaticResource PrimaryButton}"
                    IsEnabled="False"
                    Click="OnDownloadClicked"/>
        </Grid>

    </StackPanel>
</Window>
