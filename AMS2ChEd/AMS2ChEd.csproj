<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>True</UseWindowsForms>
    <PackageIcon>rewind_gp_logo_128.png</PackageIcon>
    <ApplicationIcon>StaticFiles\rewind_gp_logo_128.ico</ApplicationIcon>
	  <UpdaterProject>$(SolutionDir)..\AMS2ChEd.Updater\AMS2ChEd.Updater.csproj</UpdaterProject>
	  <UpdaterBinDir>$(SolutionDir)..\AMS2ChEd.Updater\bin\$(Configuration)\net8.0-windows\win-x64\</UpdaterBinDir>
	  <AssemblyVersion>1.5.0.0</AssemblyVersion>
	  <FileVersion>1.5.0.0</FileVersion>
  </PropertyGroup>
	
<Target Name="BuildAndCopyUpdater" AfterTargets="Build">
	<MSBuild Projects="$(UpdaterProject)" Properties="Configuration=$(Configuration);Platform=AnyCPU" Targets="Build" />

	<ItemGroup>
		<UpdaterFiles Include="$(UpdaterBinDir)**\*.*" />
	</ItemGroup>

	<Copy SourceFiles="@(UpdaterFiles)" DestinationFiles="@(UpdaterFiles->'$(OutputPath)Updater\%(RecursiveDir)%(Filename)%(Extension)')" />
</Target>
	
  <ItemGroup>
    <None Remove="Fonts\Soniano Sans Unicode Regular.ttf" />
    <None Remove="StaticFiles\rewind_gp_logo.png" />
  </ItemGroup>

  <ItemGroup>
    <Page Remove="App\App.xaml" />
  </ItemGroup>

  <ItemGroup>
    <ApplicationDefinition Include="App\App.xaml" />
  </ItemGroup>

